# -------------------------------------------------------
# MULTI-USER MODE
# -------------------------------------------------------
# If ./config/users.conf exists, multi-user mode is active.
# Each user gets their own Samba share and Paperless API key.
# See config/users.conf.example for the format.
#
# In multi-user mode, the SMB_* and PAPERLESS_API_KEY variables
# below are ignored. PAPERLESS_URL and all other settings still apply.

# -------------------------------------------------------
# SINGLE-USER MODE (default, backwards-compatible)
# -------------------------------------------------------

# Paperless-NGX API Configuration
PAPERLESS_URL=https://your-paperless-instance.com
PAPERLESS_API_KEY=your-api-key-here
PAPERLESS_VERIFY_SSL=true
PAPERLESS_TAGS=

# Samba Configuration
SMB_USER=scanner
SMB_PASSWORD=securepassword
SMB_SHARE=scanner

# Document Processing
WHITELIST=pdf,jpg,png,bmp
ARCHIVE=true
UPLOAD_TIMEOUT=30
SCAN_SETTLE_TIME=5

# User Configuration (optional, defaults to 1000:1000)
# Matches the user on your host system to avoid permission issues
PUID=1000
PGID=1000
